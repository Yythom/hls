{
  "name": "video-download",
  "version": "1.0.0",
  "description": "Desktop app for discovering and downloading video resources from web pages.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js",
    "fetch:ffmpeg": "node scripts/fetch-ffmpeg.js",
    "fetch:ytdlp": "node scripts/fetch-ytdlp.js",
    "fetch:bins": "npm run fetch:ffmpeg && npm run fetch:ytdlp",
    "predist": "npm run fetch:bins",
    "predist:mac": "npm run fetch:bins",
    "predist:win": "npm run fetch:bins",
    "dist": "rm -rf dist && electron-builder -mw",
    "dist:mac": "rm -rf dist && electron-builder --mac",
    "dist:win": "rm -rf dist && electron-builder --win"
  },
  "keywords": [
    "electron",
    "video",
    "download"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "com.yeyuteng.videodownload",
    "productName": "Video Download",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/ffmpeg/darwin-${arch}/ffmpeg",
          "to": "ffmpeg"
        },
        {
          "from": "resources/yt-dlp/darwin-${arch}/yt-dlp",
          "to": "yt-dlp"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/ffmpeg/win32-x64/ffmpeg.exe",
          "to": "ffmpeg.exe"
        },
        {
          "from": "resources/yt-dlp/win32-x64/yt-dlp.exe",
          "to": "yt-dlp.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  }
}
